{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/test-gate.js" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": []
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": []
      }
    ],
    "Stop": [
      {
        "hooks": []
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(git merge-base *)"
    ]
  }
}
